      "conversation": [
        {
          "invocation_id": "inv-orrery-001",
          "user_content": {
            "parts": [
              {
                "text": "Is the Kafka cluster healthy? I only need a quick status — don't run a full triage."
              }
            ],
            "role": "user"
          },
          "final_response": {
            "parts": [
              {
                "text": "The Kafka cluster is healthy: 2 brokers online and all topics are reporting normally."
              }
            ],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [{"name": "kafka_health_agent", "args": {}}],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "orrery_assistant",
        "user_id": "test_user",
        "state": {"user_role": "viewer"}
      }
    },
    {
